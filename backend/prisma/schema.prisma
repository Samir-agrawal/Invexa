generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  FULFILLED
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN_IN
  RETURN_OUT
}

model User {
  id                  String          @id @default(cuid())
  email               String          @unique
  passwordHash        String?
  fullName            String
  role                UserRole        @default(STAFF)
  isActive            Boolean         @default(true)
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime?
  refreshTokenVersion Int             @default(0)
  deletedAt           DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  purchaseOrders      PurchaseOrder[]
  salesOrders         SalesOrder[]
  stockMovements      StockMovement[]

  @@index([deletedAt])
  @@index([lastLoginAt])
}

model Product {
  id               String              @id @default(cuid())
  sku              String              @unique
  name             String
  category         String?
  brand            String?
  description      String?
  unitPrice        Decimal             @db.Decimal(12, 2)
  costPrice        Decimal?            @db.Decimal(12, 2)
  deletedAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  inventoryLevels  InventoryLevel[]
  stockMovements   StockMovement[]
  supplierProducts SupplierProduct[]
  purchaseItems    PurchaseOrderItem[]
  salesItems       SalesOrderItem[]
  reorderRules     ReorderRule[]

  @@index([name])
  @@index([category])
  @@index([brand])
  @@index([deletedAt])
}

model Warehouse {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  location        String?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  inventoryLevels InventoryLevel[]
  stockMovements  StockMovement[]
  purchaseOrders  PurchaseOrder[]
  salesOrders     SalesOrder[]
  reorderRules    ReorderRule[]

  @@index([name])
  @@index([deletedAt])
}

model InventoryLevel {
  id                String    @id @default(cuid())
  productId         String
  warehouseId       String
  quantityOnHand    Decimal   @default(0) @db.Decimal(14, 3)
  quantityReserved  Decimal   @default(0) @db.Decimal(14, 3)
  quantityAvailable Decimal   @default(0) @db.Decimal(14, 3)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  product           Product   @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([productId, warehouseId])
  @@index([warehouseId])
}

model StockMovement {
  id                String            @id @default(cuid())
  productId         String
  warehouseId       String
  movementType      StockMovementType
  quantity          Decimal           @db.Decimal(14, 3)
  unitCost          Decimal?          @db.Decimal(12, 2)
  referenceDocument String?
  note              String?
  createdById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  product           Product           @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  warehouse         Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdBy         User?             @relation(fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([productId, warehouseId, createdAt])
  @@index([movementType])
  @@index([createdById])
}

model Supplier {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  email            String?
  phone            String?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  supplierProducts SupplierProduct[]
  purchaseOrders   PurchaseOrder[]
  reorderRules     ReorderRule[]

  @@index([name])
  @@index([deletedAt])
}

model SupplierProduct {
  id               String   @id @default(cuid())
  supplierId       String
  productId        String
  supplierSku      String?
  supplierUnitCost Decimal? @db.Decimal(12, 2)
  leadTimeDays     Int?
  minimumOrderQty  Decimal? @db.Decimal(14, 3)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  supplier         Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([supplierId, productId])
  @@index([productId])
  @@index([supplierSku])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  orderNumber String              @unique
  supplierId  String
  warehouseId String
  status      PurchaseOrderStatus @default(DRAFT)
  orderDate   DateTime            @default(now())
  expectedAt  DateTime?
  receivedAt  DateTime?
  subtotal    Decimal             @default(0) @db.Decimal(12, 2)
  taxAmount   Decimal             @default(0) @db.Decimal(12, 2)
  totalAmount Decimal             @default(0) @db.Decimal(12, 2)
  createdById String?
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  supplier    Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  warehouse   Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdBy   User?               @relation(fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items       PurchaseOrderItem[]

  @@index([supplierId, status])
  @@index([warehouseId, status])
  @@index([orderDate])
  @@index([createdById])
  @@index([deletedAt])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String
  quantityOrdered  Decimal       @db.Decimal(14, 3)
  quantityReceived Decimal       @default(0) @db.Decimal(14, 3)
  unitCost         Decimal       @db.Decimal(12, 2)
  lineTotal        Decimal       @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product          Product       @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([purchaseOrderId, productId])
  @@index([productId])
}

model SalesOrder {
  id           String           @id @default(cuid())
  orderNumber  String           @unique
  warehouseId  String
  status       SalesOrderStatus @default(DRAFT)
  customerName String?
  orderDate    DateTime         @default(now())
  fulfilledAt  DateTime?
  subtotal     Decimal          @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal          @default(0) @db.Decimal(12, 2)
  totalAmount  Decimal          @default(0) @db.Decimal(12, 2)
  createdById  String?
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  warehouse    Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdBy    User?            @relation(fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items        SalesOrderItem[]

  @@index([warehouseId, status])
  @@index([orderDate])
  @@index([createdById])
  @@index([deletedAt])
}

model SalesOrderItem {
  id           String     @id @default(cuid())
  salesOrderId String
  productId    String
  quantity     Decimal    @db.Decimal(14, 3)
  unitPrice    Decimal    @db.Decimal(12, 2)
  lineTotal    Decimal    @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([salesOrderId, productId])
  @@index([productId])
}

model ReorderRule {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  supplierId  String?
  minLevel    Decimal   @db.Decimal(14, 3)
  reorderQty  Decimal   @db.Decimal(14, 3)
  targetLevel Decimal?  @db.Decimal(14, 3)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([productId, warehouseId])
  @@index([supplierId])
  @@index([isActive])
  @@index([deletedAt])
}
