# App
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_AUTH_MAX=25
OPENAPI_ENABLED=true
APP_BASE_URL=http://localhost:5173

# Postgres / Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/admin_dashboard?schema=public

# Auth placeholders
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=1d
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_SEED_PASSWORD=ChangeMe123!
